@inherits LayoutComponentBase
@inject IJSRuntime JS

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudButton Variant="Variant.Text" Color="Color.Tertiary" Size="Size.Large" Href="/">Overlege AI 👩‍⚕️👨‍⚕</MudButton>
        <MudButtonGroup Color="Color.Primary" Variant="Variant.Filled">
            <MudButton EndIcon="@Icons.Material.Filled.Info" Href="/How_it_works">How it works</MudButton>
            <MudButton EndIcon="@Icons.Material.Filled.AttachMoney" Href="/Price">Price</MudButton>
            <MudButton EndIcon="@Icons.Material.Filled.Done" Href="/Free">Try it for free</MudButton>
            <MudButton EndIcon="@Icons.Material.Filled.Visibility" Href="/Demo">Demo</MudButton>
        </MudButtonGroup>        
    </MudAppBar>
    <MudMainContent>

        @Body

    </MudMainContent>
</MudLayout>