@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject CloseGuardAIDemo.Web.Services.DataService DataService
@using CloseGuardAIDemo.Web.Services

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudButton Variant="Variant.Text" Color="Color.Tertiary" Size="Size.Large" Href="/">CloseGuard 💵 🤖</MudButton>
        <MudButtonGroup Color="Color.Primary" Variant="Variant.Filled">
            <MudButton @onclick="() => DataService.SetDataset(DataSet.Clean)">Generate Base Data 💹</MudButton>
            <MudSpacer/>
            <MudButton @onclick="() => DataService.SetDataset(DataSet.Deviated)">Generate Deviated Data 📈</MudButton>
            <MudSpacer />
            <MudButton @onclick="() => DataService.Analyse()">Analyse Data 🤖</MudButton>
            <MudSpacer />
            <MudButton @onclick="() => DataService.Reset()">Reset Data 🔄️</MudButton>
        </MudButtonGroup>
    </MudAppBar>
    <MudMainContent>

        @Body

    </MudMainContent>
</MudLayout>
