@page "/"
@inject CloseGuardAIDemo.Web.Services.DataService DataService
@using CloseGuardAIDemo.Web.Services
@using CloseGuardAIDemo.Web.Models
@implements IDisposable

<PageTitle>CloseGuard AI Demo</PageTitle>

<MudGrid Spacing="2" Class="pa-4">
    <MudItem xs="12">
        <MudPaper data-testid="clean-panel" Class="pa-2" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">Clean Data</MudText>
            @if (DataService.CleanData == null)
            {
                <MudText Align="Align.Center" Class="pa-4">No data yet</MudText>
            }
            else
            {
                <MudTable Items="DataService.CleanData" Dense="true" Striped="true" Hover="true"
                          RowClassFunc="@((s, _) => s.AccountId == _selectedAccountId ? "selected-row" : "")">
                    <HeaderContent>
                        <MudTh><b>Account ID</b></MudTh>
                        <MudTh><b>Account Name</b></MudTh>
                        <MudTh><b>Account Type</b></MudTh>
                        <MudTh><b>Previous Balance</b></MudTh>
                        <MudTh><b>Current Balance</b></MudTh>
                        <MudTh><b>Variance Amount</b></MudTh>
                        <MudTh><b>Variance %</b></MudTh>
                        <MudTh><b>Manual Journals</b></MudTh>
                        <MudTh><b>Largest Manual Journal</b></MudTh>
                        <MudTh><b>Unmatched Items</b></MudTh>
                        <MudTh><b>Days to Reconcile</b></MudTh>
                        <MudTh><b>Has Support Doc</b></MudTh>
                        <MudTh><b>Materiality Threshold</b></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.AccountId</MudTd>
                        <MudTd>@context.AccountName</MudTd>
                        <MudTd>@context.AccountType</MudTd>
                        <MudTd>@context.PreviousBalance.ToString("N0")</MudTd>
                        <MudTd>@context.CurrentBalance.ToString("N0")</MudTd>
                        <MudTd>@context.VarianceAmount.ToString("N0")</MudTd>
                        <MudTd>@context.VariancePercent.ToString("F1")%</MudTd>
                        <MudTd>@context.ManualJournalCount</MudTd>
                        <MudTd>@context.LargestManualJournalAmount.ToString("N0")</MudTd>
                        <MudTd>@context.UnmatchedItemCount</MudTd>
                        <MudTd>@context.DaysToCompleteReconciliation</MudTd>
                        <MudTd>@(context.HasSupportDocument ? "✓" : "✗")</MudTd>
                        <MudTd>@context.MaterialityThreshold.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper data-testid="deviated-panel" Class="pa-2" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">Deviated Data</MudText>
            @if (DataService.DeviatedData == null)
            {
                <MudText Align="Align.Center" Class="pa-4">No data yet</MudText>
            }
            else
            {
                <MudTable Items="DataService.DeviatedData" Dense="true" Striped="true" Hover="true"
                          RowClassFunc="@((s, _) => s.AccountId == _selectedAccountId ? "selected-row" : "")">
                    <HeaderContent>
                        <MudTh><b>Account ID</b></MudTh>
                        <MudTh><b>Account Name</b></MudTh>
                        <MudTh><b>Account Type</b></MudTh>
                        <MudTh><b>Previous Balance</b></MudTh>
                        <MudTh><b>Current Balance</b></MudTh>
                        <MudTh><b>Variance Amount</b></MudTh>
                        <MudTh><b>Variance %</b></MudTh>
                        <MudTh><b>Manual Journals</b></MudTh>
                        <MudTh><b>Largest Manual Journal</b></MudTh>
                        <MudTh><b>Unmatched Items</b></MudTh>
                        <MudTh><b>Days to Reconcile</b></MudTh>
                        <MudTh><b>Has Support Doc</b></MudTh>
                        <MudTh><b>Materiality Threshold</b></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.AccountId</MudTd>
                        <MudTd>@context.AccountName</MudTd>
                        <MudTd>@context.AccountType</MudTd>
                        <MudTd>@context.PreviousBalance.ToString("N0")</MudTd>
                        <MudTd>@context.CurrentBalance.ToString("N0")</MudTd>
                        <MudTd>@context.VarianceAmount.ToString("N0")</MudTd>
                        <MudTd>@context.VariancePercent.ToString("F1")%</MudTd>
                        <MudTd>@context.ManualJournalCount</MudTd>
                        <MudTd>@context.LargestManualJournalAmount.ToString("N0")</MudTd>
                        <MudTd>@context.UnmatchedItemCount</MudTd>
                        <MudTd>@context.DaysToCompleteReconciliation</MudTd>
                        <MudTd>@(context.HasSupportDocument ? "✓" : "✗")</MudTd>
                        <MudTd>@context.MaterialityThreshold.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper data-testid="analysis-panel" Class="pa-2" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">Exception Analysis</MudText>
            @if (DataService.AnalysisResults == null)
            {
                <MudText Align="Align.Center" Class="pa-4">Run analysis to see results</MudText>
            }
            else
            {
                <MudTable T="ExceptionResult" Items="DataService.AnalysisResults" Dense="true" Striped="true" Hover="true"
                          OnRowClick="OnAnalysisRowClick"
                          RowClassFunc="@((r, _) => r.AccountId == _selectedAccountId ? "selected-row" : "")">
                    <HeaderContent>
                        <MudTh><b>Account Name</b></MudTh>
                        <MudTh><b>Risk Score</b></MudTh>
                        <MudTh><b>Severity</b></MudTh>
                        <MudTh><b>Likely Cause</b></MudTh>
                        <MudTh><b>Variance Amount</b></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.AccountName</MudTd>
                        <MudTd>@context.RiskScore.ToString("F2")</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@SeverityColor(context.Severity)" Size="Size.Small">
                                @context.Severity
                            </MudChip>
                        </MudTd>
                        <MudTd>@context.LikelyCause</MudTd>
                        <MudTd>@context.VarianceAmount.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string? _selectedAccountId;

    protected override void OnInitialized()
    {
        DataService.StateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.StateChanged -= OnStateChanged;
    }

    private void OnAnalysisRowClick(TableRowClickEventArgs<ExceptionResult> args)
    {
        if (args.Item is null) return;
        _selectedAccountId = _selectedAccountId == args.Item.AccountId
            ? null
            : args.Item.AccountId;
    }

    private static Color SeverityColor(CloseGuardAIDemo.Web.Models.Severity severity) => severity switch
    {
        CloseGuardAIDemo.Web.Models.Severity.High   => Color.Error,
        CloseGuardAIDemo.Web.Models.Severity.Medium => Color.Warning,
        _                                           => Color.Success,
    };
}
